# Local development secrets for `supabase functions serve --env-file`.
# Do not commit real values.
#
# ── Project environments ──
# Rwanda (RW): project ref kczghhipbyykluuiiunp — country code 250, currency RWF
# Malta  (MT): project ref uskfnszcdqpcfrhjxitl — country code 356, currency EUR
#
# The DEFAULT_WHATSAPP_COUNTRY_CODE below must match the target project.

DEFAULT_WHATSAPP_COUNTRY_CODE=356    # 250 for RW, 356 for MT
WHATSAPP_GRAPH_API_VERSION=v22.0
WHATSAPP_OTP_TTL_MINUTES=10
WHATSAPP_OTP_MAX_ATTEMPTS=5
WHATSAPP_OTP_REQUEST_LIMIT=3
WHATSAPP_OTP_REQUEST_WINDOW_MINUTES=5
WHATSAPP_OTP_PEPPER=replace-with-a-random-secret
DINEIN_ADMIN_SESSION_SECRET=replace-with-a-long-random-secret
DINEIN_ADMIN_SESSION_TTL_MINUTES=720

# Set to true only for local UI work when Cloud API credentials are absent.
WHATSAPP_OTP_ALLOW_MOCK=false
WHATSAPP_OTP_ALLOW_TEXT_FALLBACK=false
WHATSAPP_OTP_ALLOW_TEST_OVERRIDE=false
WHATSAPP_OTP_TEST_PHONE=
WHATSAPP_OTP_TEST_CODE=
WHATSAPP_OTP_TEST_SCOPE=admin

# Required for real WhatsApp Cloud API delivery.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_TEMPLATE_URL_BUTTON_INDEX=0

# Menu image generation secrets.
GEMINI_API_KEY=
GEMINI_IMAGE_MODELS=gemini-3.1-flash-image-preview,gemini-2.5-flash-image
MENU_IMAGE_BUCKET=menu-images
MENU_IMAGE_CRON_SECRET=

# Venue profile enrichment secrets.
GEMINI_VENUE_MODELS=gemini-2.5-flash,gemini-2.5-flash-lite
VENUE_ENRICHMENT_CRON_SECRET=

# Venue profile image generation secrets.
GEMINI_VENUE_IMAGE_MODELS=gemini-2.5-flash-image
VENUE_IMAGE_BUCKET=venue-images
VENUE_IMAGE_CRON_SECRET=

# Firebase Cloud Messaging secrets for venue operational push alerts.
FIREBASE_PROJECT_ID=gen-lang-client-0172279957
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# BioPay secrets (RW only).
BIOPAY_OWNER_TOKEN_SECRET=
BIOPAY_OWNER_TOKEN_TTL_MINUTES=259200
BIOPAY_MANAGE_CODE_PEPPER=
BIOPAY_MANAGE_CODE_LENGTH=6
BIOPAY_DEFAULT_MATCH_THRESHOLD=0.72
BIOPAY_MIN_MATCH_THRESHOLD=0.80
BIOPAY_DUPLICATE_FACE_THRESHOLD=0.90
BIOPAY_MATCH_RATE_LIMIT_WINDOW_MINUTES=5
BIOPAY_MATCH_RATE_LIMIT_MAX_REQUESTS=20
BIOPAY_RATE_LIMIT_SECRET=
